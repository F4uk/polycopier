#!/usr/bin/env bash
# Pre-commit hook: runs the same checks as CI so nothing fails on push.
# Install once after cloning:  git config core.hooksPath .githooks

set -e

echo "▶ cargo fmt --check"
cargo fmt --check

echo "▶ cargo clippy --all-targets -- -D warnings"
cargo clippy --all-targets -- -D warnings

echo "▶ cargo test --all"
cargo test --all

echo "✓ All pre-commit checks passed."
